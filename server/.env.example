# Apple Pay Backend - Environment Configuration Example
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control

# ============ ENVIRONMENT ============
NODE_ENV=production
PORT=3000

# ============ APPLE PAY CONFIGURATION ============
# Your Apple merchant identifier (from Apple Developer Portal)
APPLE_MERCHANT_ID=merchant.com.sfmamelodwest.giving

# Sandbox mode (set to false for PRODUCTION)
SANDBOX_MODE=false

# ============ CERTIFICATES ============
# Paths to merchant certificates (obtained from Apple Developer)
APPLE_PAY_CERT_PATH=/opt/apple-pay-server/certs/merchant-certificate.pem
APPLE_PAY_KEY_PATH=/opt/apple-pay-server/certs/merchant-key.pem

# Paths to server SSL certificates
SERVER_KEY_PATH=/opt/apple-pay-server/certs/server-key.pem
SERVER_CERT_PATH=/opt/apple-pay-server/certs/server-cert.pem

# ============ DOMAIN CONFIGURATION ============
# Comma-separated list of allowed domains (CORS)
ALLOWED_DOMAINS=sfmamelodwest.co.za,www.sfmamelodwest.co.za

# ============ PAYMENT PROCESSOR ============
# Choose your payment processor and add credentials below

# --- STRIPE INTEGRATION ---
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY

# --- SQUARE INTEGRATION (alternative) ---
# SQUARE_ACCESS_TOKEN=sq_live_YOUR_SQUARE_ACCESS_TOKEN
# SQUARE_ENVIRONMENT=production
# SQUARE_LOCATION_ID=YOUR_LOCATION_ID

# --- PAYPAL INTEGRATION (alternative) ---
# PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
# PAYPAL_SECRET=YOUR_PAYPAL_SECRET
# PAYPAL_MODE=live

# ============ LOGGING & MONITORING ============
LOG_LEVEL=info

# Sentry for error tracking (optional)
# SENTRY_DSN=https://YOUR_SENTRY_DSN@sentry.io/PROJECT_ID

# ============ EMAIL NOTIFICATIONS ============
# For sending donation receipts

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=giving@sfmamelodwest.co.za

# ============ SECURITY ============
# CSRF protection (optional, if not handled in frontend)
CSRF_SECRET=your-random-secret-key-here

# JWT secrets (for additional authentication if needed)
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRY=7d

# ============ DATABASE (if storing donations) ============
# MongoDB example
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/database

# PostgreSQL example  
# DATABASE_URL=postgresql://user:password@localhost:5432/church_db

# ============ FEATURES & FLAGS ============
# Enable/disable features
ENABLE_EMAIL_RECEIPTS=true
ENABLE_SMS_NOTIFICATIONS=false
REQUIRE_EMAIL_CONFIRMATION=true

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============ WEBHOOKS ============
# For payment processor callbacks
WEBHOOK_SECRET_STRIPE=whsec_test_...

# ============ SUPPORT & CONTACT ============
SUPPORT_EMAIL=info@sfmamelodwest.co.za
SUPPORT_PHONE=+27814421719
